    "sections": [
        {
            "sectionId": "grammar-10-1",
            "heading": {
                "en": "Grammar Focus: Connecting Sentences",
                "th": "เน้นไวยากรณ์: การเชื่อมประโยค",
                "fa": "تمرکز گرامر: پیوند دادن جملات"
            },
            "content": [
                {
                    "type": "paragraph",
                    "heading": {
                        "en": "Grammar Explanation",
                        "th": "คำอธิบายไวยากรณ์",
                        "fa": "توضیح گرامر"
                    },
                    "grammar": {
                        "pattern": "Clause 1 + Connector + Clause 2",
                        "note": {
                            "en": "Use connectors like และ (and), แต่ (but), เพราะ (because) to join sentences together. The word order stays the same in each clause.",
                            "th": "ใช้คำเชื่อมเช่น และ แต่ เพราะ เพื่อเชื่อมประโยคเข้าด้วยกัน ลำดับคำในแต่ละประโยคคงเดิม",
                            "fa": "از کلمات ربط مانند และ (و), แต่ (اما), เพราะ (چون) برای پیوند دادن جملات استفاده کنید. ترتیب کلمات در هر بخش ثابت می‌ماند."
                        },
                        "examples": [
                            {
                                "source": "ผมกินข้าว และดื่มน้ำ",
                                "translation": "I eat rice and drink water"
                            },
                            {
                                "source": "เขาอยากไปแต่ไม่ว่าง",
                                "translation": "He wants to go but is busy"
                            },
                            {
                                "source": "ฉันไม่ไปเพราะฝนตก",
                                "translation": "I'm not going because it's raining"
                            }
                        ]
                    },
                    "sentences": [ ]
                },
                {
                    "type": "paragraph",
                    "heading": {
                        "en": "Practice 1: Connecting Ideas",
                        "th": "ฝึกหัด 1: การเชื่อมโยงความคิด",
                        "fa": "تمرین ۱: پیوند دادن ایده‌ها"
                    },
