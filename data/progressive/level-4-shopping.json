                                "ดี",
                                "ครับ",
                                "ขอ",
                                "สอง",
                                "กิโล",
                                "ครับ"
                            ],
                            "translations": {
                                "en": "That's cheap. I'll take two kilos",
                                "fa": "ارزان است. دو کیلو می‌خواهم"
                            },
                            "originalSource": "ถูกดีครับขอสองกิโลครับ"
                        },
                        {
                            "source": "ได้ค่ะรวมเป็นหนึ่งร้อยบาทค่ะ",
