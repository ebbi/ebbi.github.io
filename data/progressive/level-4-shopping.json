                "en": "Conversation 1: At the Market",
                "th": "บทสนทนา 1: ที่ตลาด",
                "fa": "مکالمه ۱: در بازار"
            },
            "content": [
                {
                    "type": "paragraph",
                    "sentences": [
                        {
                            "source": "สวัสดีครับส้มราคาเท่าไหร่ครับ",
                            "wordIds": [
                                "สวัสดี",
                                "ครับ",
                                "ส้ม",
                                "ราคา",
                                "เท่าไหร่",
                                "ครับ"
                            ],
                            "translations": {
                                "en": "Hello, how much are the oranges?",
                                "fa": "سلام، پرتقال چنده؟"
                            },
                            "originalSource": "สวัสดีครับส้มราคาเท่าไหร่ครับ"
                        },
                        {
                            "source": "ส้มโลละห้าสิบบาทค่ะ",
                            "wordIds": [
                                "ส้ม",
                                "โล",
                                "ละ",
                                "ห้า",
                                "สิบ",
                                "บาท",
                                "ค่ะ"
                            ],
                            "translations": {
                                "en": "Oranges are 50 baht per kilo",
                                "fa": "پرتقال کیلویی ۵۰ بات"
                            },
                            "originalSource": "ส้มโลละห้าสิบบาทค่ะ"
                        },
                        {
                            "source": "ถูกดีครับขอสองกิโลครับ",
